# CourtManager Pro — variables de entorno

# === PRODUCCIÓN (Carlos / Real Madrid) ===
# Con Supabase configurado y sin DEMO_MODE, la app opera en modo real.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
NEXT_PUBLIC_APP_URL=https://courtmanagerpro.vercel.app

# Dejar sin definir o en false para producción real:
# NEXT_PUBLIC_DEMO_MODE=false

# IA — arsenal 6 proveedores (ping: GET /api/ai/ping?secret=)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
MANUS_API_KEY=
FAL_KEY=
AI_PING_SECRET=

