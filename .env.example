# CourtManager Pro — variables de entorno

# === PRODUCCIÓN (Carlos / Real Madrid) ===
# Con Supabase configurado y sin DEMO_MODE, la app opera en modo real.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
NEXT_PUBLIC_APP_URL=https://courtmanagerpro.vercel.app

# Dejar sin definir o en false para producción real:
# NEXT_PUBLIC_DEMO_MODE=false

# === DEMO COMERCIAL (multi-club, datos ficticios) ===
# NEXT_PUBLIC_DEMO_MODE=true
